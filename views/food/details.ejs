<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cute Zoo</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body>
<header>
    <img src="https://www.sciencealert.com/images/2021-10/processed/PandasInATree_1024.jpg" alt="The group of pandas">
    <h1>Cute Zoo</h1>
    <div class="auth-buttons">
        <a href="/register-zookeeper" class="button large">Register as zookeeper</a>
        <a href="/register" class="button">Register</a>
        <a href="/login" class="button">Login</a>
        <a href="/logout" class="button">Logout</a>
    </div>
</header>

<main>
    <h1>View detailed info about selected food</h1>
    <section class="food-info">
        <h2><%= food.Name %></h2>
        <table>
            <tr>
                <th>Id</th>
                <td><%= food.Id %></td>
            </tr>
            <tr>
                <th>Name</th>
                <td><%= food.Name %></td>
            </tr>
            <tr>
                <th>Calories</th>
                <td><%= food.Calories %></td>
            </tr>
        </table>
    </section>


    <section class="food-animals">
        <h2>Animals</h2>
        <% if (food.Animals.length > 0) { %>
            <table>
                <tr>
                    <th>Animal Name</th>
                    <th>Breed</th>
                    <th>Zookeeper</th>
                    <th>Quantity</th>
                </tr>
                <% food.Animals.forEach(animal => { %>
                    <tr>
                        <td><%= animal.Name %></td>
                        <td><%= animal.Breed %></td>
                        <td><a href="/zookeepers/<%= animal.Zookeeper.Id %>"><img class="actions" src="https://icon2.cleanpng.com/20180319/trq/avexs1y3m.webp" alt="View details image"></a></td>
                        <td><%= animal.Quantity %></td>
                    </tr>
                <% }); %>
            </table>
        <% } else { %>
            <p>No animals are permitted to eat this food.</p>
        <% } %>
    </section>

    <section>
        <div class="links-to-lists">
            <a href="/food">Return to list of all food</a>
        </div>
    </section>

</main>

<footer>
    <p>Vladyslava Bucharska</p>
</footer>
</body>
</html>